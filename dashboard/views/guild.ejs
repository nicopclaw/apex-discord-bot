<!DOCTYPE html>
<html>
<head>
  <title>Guild <%= guild.guild_id %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="container">
  <div class="nav">
    <a href="/admin/guilds" class="btn">Back to Guilds</a>
  </div>
  <h1>Guild <%= guild.guild_id %></h1>
  <p>Plan: <span class="badge badge-<%= guild.plan %>"><%= guild.plan %></span></p>

  <div class="card">
    <h3>Configuration</h3>
    <form action="/admin/guild/<%= guild.guild_id %>/config" method="post">
      <label>Welcome Message</label>
      <textarea name="welcomeMessage" rows="3"><%= settings.welcomeMessage || '' %></textarea>
      <button class="btn">Save</button>
    </form>
  </div>

  <div class="card">
    <h3>Tiers</h3>
    <table>
      <tr><th>Name</th><th>Role ID</th><th>Price</th><th>Actions</th></tr>
      <% tiers.forEach(t => { %>
        <tr>
          <td><%= t.tier_name %></td>
          <td><%= t.role_id %></td>
          <td><%= t.price %></td>
          <td><button class="btn btn-sm btn-danger" onclick="deleteTier('<%= t.tier_name %>')">Delete</button></td>
        </tr>
      <% }) %>
    </table>
    <h4>Add Tier</h4>
    <form action="/admin/guild/<%= guild.guild_id %>/tiers" method="post">
      <input type="text" name="tier_name" placeholder="Tier Name" required>
      <input type="number" name="role_id" placeholder="Discord Role ID" required>
      <input type="number" step="0.01" name="price" placeholder="Price" required>
      <input type="text" name="description" placeholder="Description">
      <button class="btn" type="submit">Add Tier</button>
    </form>
  </div>

  <div class="card">
    <h3>Billing</h3>
    <% if (guild.stripe_customer_id) { %>
      <form action="/stripe/portal" method="post" target="_blank">
        <input type="hidden" name="customerId" value="<%= guild.stripe_customer_id %>">
        <button class="btn">Manage Subscription (Stripe Portal)</button>
      </form>
    <% } else { %>
      <p>No Stripe customer on file. Upgrade via bot commands in Discord.</p>
    <% } %>
  </div>
</div>

<script>
async function deleteTier(name) {
  if (!confirm('Delete tier ' + name + '?')) return;
  const res = await fetch('/admin/guild/<%= guild.guild_id %>/tiers/' + name, { method: 'DELETE' });
  if (res.ok) location.reload();
  else alert('Failed');
}
</script>
</body>
</html>